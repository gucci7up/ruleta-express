# ── Base de datos ─────────────────────────────────────────────
POSTGRES_USER=ruleta
POSTGRES_PASSWORD=cambia_esto_por_password_fuerte
POSTGRES_DB=ruleta_express

# ── Redis ──────────────────────────────────────────────────────
REDIS_PASSWORD=cambia_esto_por_password_redis

# ── JWT (genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))") ──
JWT_SECRET=genera_64_chars_aqui
JWT_REFRESH_SECRET=genera_64_chars_diferentes_aqui

# ── URLs públicas (usadas por los frontends en runtime) ────────
# URL de la API (sin barra final)
API_URL=https://api.tudominio.com

# URL del POS (para los QR de los tickets)
POS_URL=https://pos.tudominio.com

# ── Display ────────────────────────────────────────────────────
# ID de la sucursal que mostrará la pantalla TV
BRANCH_ID=1
