# PostgreSQL
POSTGRES_USER=ruleta
POSTGRES_PASSWORD=ruleta_secret
POSTGRES_DB=ruleta_express

# Redis
REDIS_PASSWORD=redis_secret

# pgAdmin
PGADMIN_EMAIL=admin@ruleta.com
PGADMIN_PASSWORD=admin123

# API
DATABASE_URL="postgresql://ruleta:ruleta_secret@localhost:5432/ruleta_express?schema=public"
REDIS_URL="redis://:redis_secret@localhost:6379"
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
PORT=3000
FRONTEND_URL=http://localhost:5173

# Frontend (POS)
VITE_API_URL=http://localhost:3000
VITE_WS_URL=http://localhost:3000

# Frontend (Admin)
VITE_ADMIN_API_URL=http://localhost:3000

# Frontend (Display)
VITE_DISPLAY_API_URL=http://localhost:3000
VITE_DISPLAY_WS_URL=http://localhost:3000
